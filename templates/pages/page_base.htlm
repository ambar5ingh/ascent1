<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ASCENT — {{ page_title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/main.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/results.css') }}">
  <style>
    /* ── Page nav pills ── */
    .page-nav {
      display: flex; flex-wrap: wrap; gap: 6px;
      padding: 12px 24px;
      background: #f8fafc;
      border-bottom: 1px solid var(--border);
    }
    .page-nav a {
      font-size: 0.72rem; font-weight: 600;
      padding: 5px 12px; border-radius: 100px;
      text-decoration: none;
      border: 1.5px solid var(--border);
      color: var(--muted);
      background: var(--card);
      transition: all 0.18s;
      white-space: nowrap;
    }
    .page-nav a:hover { border-color: var(--teal); color: var(--teal); }
    .page-nav a.active {
      background: var(--navy); color: #fff; border-color: var(--navy);
    }
    /* ── Inventory table subtotals ── */
    .data-table tr.subtotal-row td {
      background: rgba(0,180,166,0.07);
      font-weight: 700; color: var(--navy);
      border-top: 2px solid rgba(0,180,166,0.3);
    }
    /* ── Scenario value cards ── */
    .scenario-strip {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(160px,1fr));
      gap: 12px; margin-bottom: 20px;
    }
    .scen-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 16px;
      box-shadow: var(--shadow);
    }
    .scen-card-label { font-size: 0.68rem; font-weight: 700; color: var(--muted);
                       letter-spacing:.05em; text-transform:uppercase; margin-bottom:6px; }
    .scen-card-val   { font-family: var(--font-display); font-size: 1.6rem;
                       font-weight: 800; color: var(--navy); line-height:1; }
    .scen-card-unit  { font-size: 0.65rem; color: var(--muted); margin-top:3px; }
    .scen-card.teal  { border-top: 3px solid var(--teal); }
    .scen-card.navy  { border-top: 3px solid var(--navy); }
    .scen-card.green { border-top: 3px solid var(--green); }
    .scen-card.amber { border-top: 3px solid var(--amber); }
    .scen-card.blue  { border-top: 3px solid var(--blue); }
  </style>
</head>
<body class="results-body">
<div class="bg-grid"></div>
 
<!-- ── Header ── -->
<header class="results-header">
  <div class="rh-left">
    <a href="/results" class="back-link">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      Results
    </a>
    <div class="logo-mark small">
      <svg width="22" height="22" viewBox="0 0 32 32" fill="none">
        <path d="M16 2L28 8V24L16 30L4 24V8L16 2Z" stroke="var(--teal)" stroke-width="1.5" fill="none"/>
        <circle cx="16" cy="16" r="3" fill="var(--teal)"/>
      </svg>
    </div>
    <span class="rh-title">{{ page_title }}</span>
  </div>
  <div class="rh-city" id="rhCity">—</div>
</header>
 
<!-- ── Sub-page nav pills ── -->
<nav class="page-nav">
  {% set pages = [
    ("emission-profile", "Emission Profile"),
    ("base-inventory",   "GHG Inventory"),
    ("bau-scenario",     "BAU Scenario"),
    ("bau-district",     "BAU Dashboard"),
    ("target-setting",   "Target Setting"),
    ("ep-scenario",      "E&amp;P Scenario"),
    ("ha-scenario",      "High Ambition"),
    ("emission-graph",   "Reduction Graph"),
    ("scenario-compare", "Scenario Comparison"),
  ] %}
  {% for slug, label in pages %}
  <a href="/pages/{{ slug }}"
     class="{% if slug == page_slug %}active{% endif %}">
    {{ label }}
  </a>
  {% endfor %}
</nav>
 
<!-- ── Loading overlay ── -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-card">
    <div class="loading-hex">
      <svg width="60" height="60" viewBox="0 0 32 32" fill="none">
        <path d="M16 2L28 8V24L16 30L4 24V8L16 2Z"
              stroke="var(--teal)" stroke-width="1.5" fill="none" class="hex-pulse"/>
        <circle cx="16" cy="16" r="3" fill="var(--teal)"/>
      </svg>
    </div>
    <h3 class="loading-title">Loading {{ page_title }}</h3>
    <p class="loading-sub">Running calculations…</p>
  </div>
</div>
 
<!-- ── Error banner ── -->
<div class="error-banner hidden" id="errorBanner">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
    <line x1="12" y1="16" x2="12.01" y2="16"/>
  </svg>
  <span id="errorMsg">No form data found. Please complete the questionnaire first.</span>
  <a href="/" class="error-back">← Start Over</a>
</div>
 
<!-- ── Dashboard container (filled by JS) ── -->
<main class="dashboard hidden" id="dashboard"></main>
 
<footer class="site-footer">
  <p>ASCENT v2.0 · WRI India · IPCC 2019 GPC Framework · AR6 GWP (CH₄=29.8, N₂O=273)</p>
</footer>
 
<script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
<script>
  // Pass the current page slug to the JS loader
  const PAGE_SLUG = "{{ page_slug }}";
</script>
<script src="{{ url_for('static', filename='js/page_loader.js') }}"></script>
</body>
</html>
